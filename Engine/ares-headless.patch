index 029c8de9..3b867492 100644
--- a/ares/ares/platform.hpp
+++ b/ares/ares/platform.hpp
@@ -13,6 +13,38 @@ enum class Event : u32 {
   Shutdown
 };
 
+struct WonderSwanDisplayProvenance {
+  u32 x;
+  u32 y;
+  u32 layer;
+  u32 sourceKind;
+  u32 cellAddress;
+  u32 cellAttributes;
+  u32 cellByteCount;
+  u32 tile;
+  u32 rasterAddress;
+  u32 rasterByteCount;
+  u32 palette;
+  u32 paletteColor;
+  u32 paletteAddress;
+  u32 paletteByteCount;
+  u32 oamAddress;
+  u32 oamByteCount;
+};
+
+struct WonderSwanInstructionFetchOrigin {
+  u64 token;
+  u32 sourceKind;
+  u32 physicalAddress;
+  u32 resolvedOperand;
+  u32 mapperWindow;
+  u32 mapperBank;
+  u32 eventContext;
+  u32 segment;
+  u32 offset;
+  u32 data;
+};
+
 struct Platform {
   virtual auto attach(Node::Object) -> void {}
   virtual auto detach(Node::Object) -> void {}
@@ -25,6 +57,20 @@ struct Platform {
   virtual auto audio(Node::Audio::Stream) -> void {}
   virtual auto input(Node::Input::Input) -> void {}
   virtual auto cheat(u32 addr) -> maybe<u32> { return nothing; }
+  virtual auto rtcTime() -> u64 { return chrono::timestamp(); }
+  virtual auto wonderSwanInstructionBegin(u32 writer, u32 segment, u32 offset) -> void {}
+  virtual auto wonderSwanInstructionDataflow(u32 kind) -> void {}
+  virtual auto wonderSwanInstructionEnd() -> void {}
+  virtual auto wonderSwanInstructionFetch(const WonderSwanInstructionFetchOrigin&) -> void {}
+  virtual auto wonderSwanInstructionBoundary(u32 opcode, u64 opcodeOrigin, bool continuing) -> void {}
+  virtual auto wonderSwanPrefetchFlush(u32 generation) -> void {}
+  virtual auto wonderSwanPrefetchInvalid() -> void {}
+  virtual auto wonderSwanDataRead(u32 kind, u32 address) -> void {}
+  virtual auto wonderSwanCartridgeDataRead(u32 resolvedOperand, u32 operandSegment, u32 operandOffset, u32 mapperWindow, u32 mapperBank) -> void {}
+  virtual auto wonderSwanRegisterRead(u32 index) -> void {}
+  virtual auto wonderSwanRegisterWrite(u32 index) -> void {}
+  virtual auto wonderSwanSourceWrite(u32 kind, u32 address, u32 writer) -> void {}
+  virtual auto wonderSwanDisplayProvenance(const WonderSwanDisplayProvenance&) -> void {}
 };
 
 extern Platform* platform;
diff --git a/ares/component/processor/v30mz/instruction.cpp b/ares/component/processor/v30mz/instruction.cpp
index 13329e0a..53eb6e4b 100644
--- a/ares/component/processor/v30mz/instruction.cpp
+++ b/ares/component/processor/v30mz/instruction.cpp
@@ -60,7 +60,9 @@ auto V30MZ::instruction() -> void {
   state.prefix = 0;
   if(state.halt) return wait(1);
 
-  switch(opcode = fetch<Byte>()) {
+  opcode = fetch<Byte>();
+  opcodeOrigin = consumedFetchOrigin;
+  switch(opcode) {
   op(0x00, AddMemReg<Byte>)
   op(0x01, AddMemReg<Word>)
   op(0x02, AddRegMem<Byte>)
@@ -319,6 +321,7 @@ auto V30MZ::instruction() -> void {
   op(0xff, Group4MemImm<Word>)
   }
 
+  provenanceInstructionBoundary(opcode, opcodeOrigin, state.prefix);
   if(!state.prefix) prefixFlush();
   if(state.poll && state.nmi) interrupt(2, InterruptSource::NMI);
   if(state.poll && state.brk) interrupt(1, InterruptSource::SingleStep);
