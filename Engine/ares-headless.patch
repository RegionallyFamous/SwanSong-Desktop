+    u32 mapperBank;
+    switch(mapperWindow) {
+    case 2:  mapperBank = cartridge.io.romBank0; break;
+    case 3:  mapperBank = cartridge.io.romBank1; break;
+    default: mapperBank = cartridge.io.romBank2; break;
+    }
+    return platform->wonderSwanCartridgeDataRead(
+      cartridge.romOffset(address), segment, offset, mapperWindow, mapperBank
+    );
+  }
+}
