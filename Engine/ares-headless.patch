+auto PPU::rasterAddress(n10 tile, n3 x, n3 y) -> u32 {
+  tile &= grayscale() ? 0x1ff : 0x3ff;
+  if(depth() == 2) {
+    auto address = 0x2000 + (tile << 4) + (y << 1);
+    return packed() ? address + (x >> 2) : address;
+  }
+  auto address = 0x4000 + (tile << 5) + (y << 2);
+  return packed() ? address + (x >> 1) : address;
+}
+
+auto PPU::rasterByteCount() -> u32 {
+  if(packed()) return 1;
+  return depth() == 2 ? 2 : 4;
+}
+
+auto PPU::paletteAddress(n4 palette, n4 color) -> u32 {
+  if(grayscale()) {
+    return 0x10000 + 0x20 + (palette << 1) + ((color & 3) >> 1);
+  }
+  return 0xfe00 + (palette << 5) + (color << 1);
+}
+
+auto PPU::paletteByteCount() -> u32 {
+  return grayscale() ? 1 : 2;
+}
