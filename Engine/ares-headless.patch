diff --git a/CMakeLists.txt b/CMakeLists.txt
index 0c5247e0..6cc4d77d 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -4,6 +4,8 @@ include("${CMAKE_CURRENT_SOURCE_DIR}/cmake/common/bootstrap.cmake" NO_POLICY_SCO
 
 project(ares VERSION ${ARES_VERSION_CANONICAL})
 
+option(ARES_HEADLESS_CORE_ONLY "Build emulator cores without the ares desktop frontend" OFF)
+
 include(compilerconfig)
 include(defaults)
 include(helpers)
@@ -12,8 +14,10 @@ add_subdirectory(thirdparty)
 
 add_subdirectory(nall/nall)
 add_subdirectory(libco)
-add_subdirectory(ruby)
-add_subdirectory(hiro)
+if(NOT ARES_HEADLESS_CORE_ONLY)
+  add_subdirectory(ruby)
+  add_subdirectory(hiro)
+endif()
 
 # gersemi: off
 set(
@@ -24,8 +28,10 @@ set(
 # gersemi: on
 
 add_subdirectory(ares)
-add_subdirectory(mia)
-add_subdirectory(desktop-ui)
+if(NOT ARES_HEADLESS_CORE_ONLY)
+  add_subdirectory(mia)
+  add_subdirectory(desktop-ui)
+endif()
 
 option(ARES_BUILD_OPTIONAL_TARGETS "Include supplemental tools and tests" OFF)
 
@@ -49,8 +55,12 @@ endif()
 
 add_subdirectory(tools/sourcery)
 
-message_configuration()
+if(NOT ARES_HEADLESS_CORE_ONLY)
+  message_configuration()
+endif()
 
-add_subdirectory(.github)
+if(NOT ARES_HEADLESS_CORE_ONLY)
+  add_subdirectory(.github)
+endif()
 add_subdirectory(cmake)
 return()
